# PostgreSQL
DB_USER=scanner
DB_PASS=CHANGE_ME
DB_NAME=scanner_frontend

# API authentication
API_KEY=CHANGE_ME

# Host port (HTTPS)
APP_PORT=8445

# AWS credentials (passed through to scanner container for AI scanning)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Scanner output directory — must be a HOST path (Docker socket mounts are host-relative)
SCANNER_OUTPUT_DIR=./data/scanner-output

# TLS certificates (mkcert or similar)
TLS_CERT_PATH=/path/to/cert.pem
TLS_KEY_PATH=/path/to/key.pem
